---
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/sections/Header.astro';
import Footer from '../../components/sections/Footer.astro';

export const getStaticPaths = (async () => {
  const blogPosts = await getCollection('blog');
  return blogPosts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const { Content } = await post.render();

const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter(p => p.data.category === post.data.category && p.slug !== post.slug)
  .slice(0, 3);

const formatDate = (date: Date) =>
  date.toLocaleDateString('es-CL', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Layout
  title={`${post.data.title} | Blog Plan de Medios`}
  description={post.data.description}
>
  <Header />

  <main class="blog-post">
    <!-- Hero Header -->
    <header class="post-hero">
      <div class="post-hero-inner">
        <a href="/#noticias" class="back-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          Volver
        </a>
        <span class="post-cat">{post.data.category}</span>
        <h1 class="post-title">{post.data.title}</h1>
        <p class="post-desc">{post.data.description}</p>
        <div class="post-meta">
          <span>{post.data.author}</span>
          <span class="meta-dot"></span>
          <time>{formatDate(post.data.publishDate)}</time>
          <span class="meta-dot"></span>
          <span>{post.data.readTime} de lectura</span>
        </div>
      </div>
    </header>

    <!-- Article Body -->
    <article class="post-body">
      <div class="post-body-inner">
        {post.data.image && (
          <div class="post-image">
            <img src={post.data.image} alt={post.data.title} />
          </div>
        )}
        <div class="prose">
          <Content />
        </div>

        {post.data.tags && post.data.tags.length > 0 && (
          <div class="post-tags">
            {post.data.tags.map(tag => (
              <span class="tag">#{tag}</span>
            ))}
          </div>
        )}
      </div>
    </article>

    <!-- Related -->
    {relatedPosts.length > 0 && (
      <section class="related">
        <div class="related-inner">
          <h3 class="related-heading">Artículos relacionados</h3>
          <div class="related-grid">
            {relatedPosts.map(rp => (
              <a href={`/blog/${rp.slug}`} class="related-card">
                <span class="related-cat">{rp.data.category}</span>
                <h4 class="related-title">{rp.data.title}</h4>
                <p class="related-desc">{rp.data.description}</p>
                <span class="related-link">Leer más →</span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}
  </main>

  <Footer />
</Layout>

<style>
  /* ── Hero ── */
  .post-hero {
    background: linear-gradient(170deg, #020617 0%, #0c1222 100%);
    padding: 8rem 0 4rem;
  }

  .post-hero-inner {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: #64748b;
    text-decoration: none;
    margin-bottom: 2rem;
    transition: color 0.2s ease;
  }

  .back-link:hover {
    color: #2dd4bf;
  }

  .post-cat {
    display: inline-block;
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #2dd4bf;
    margin-bottom: 1rem;
    padding: 0.25rem 0.75rem;
    background: rgba(20, 184, 166, 0.1);
    border-radius: 6px;
  }

  .post-title {
    font-family: var(--font-heading);
    font-size: 2.75rem;
    font-weight: 400;
    line-height: 1.12;
    color: #f1f5f9;
    letter-spacing: -0.01em;
    margin: 0 0 1.25rem;
  }

  .post-desc {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: #94a3b8;
    margin: 0 0 2rem;
  }

  .post-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: #64748b;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .meta-dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: #475569;
  }

  /* ── Body ── */
  .post-body {
    background: white;
    padding: 3.5rem 0 4rem;
  }

  .post-body-inner {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .post-image {
    margin-bottom: 2.5rem;
    border-radius: 12px;
    overflow: hidden;
  }

  .post-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ── Prose ── */
  .prose {
    font-size: 1.0625rem;
    line-height: 1.8;
    color: #334155;
  }

  .prose :global(h2) {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 400;
    color: #111827;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }

  .prose :global(h3) {
    font-family: var(--font-heading);
    font-size: 1.375rem;
    font-weight: 400;
    color: #111827;
    margin-top: 2rem;
    margin-bottom: 0.625rem;
  }

  .prose :global(h4) {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    font-weight: 600;
    color: #111827;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .prose :global(p) {
    margin-bottom: 1.25rem;
    color: #334155;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
    color: #334155;
  }

  .prose :global(li) {
    margin-bottom: 0.5rem;
  }

  .prose :global(strong) {
    font-weight: 600;
    color: #111827;
  }

  .prose :global(a) {
    color: #14b8a6;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .prose :global(a:hover) {
    color: #0d9488;
  }

  .prose :global(blockquote) {
    border-left: 3px solid #14b8a6;
    padding-left: 1.25rem;
    margin: 2rem 0;
    font-style: italic;
    color: #64748b;
  }

  /* ── Tags ── */
  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid #e2e8f0;
  }

  .tag {
    font-size: 0.75rem;
    font-weight: 500;
    color: #64748b;
    padding: 0.25rem 0.75rem;
    background: #f1f5f9;
    border-radius: 6px;
  }

  /* ── Related ── */
  .related {
    background: #f8fafc;
    padding: 4rem 0;
  }

  .related-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .related-heading {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 400;
    color: #111827;
    margin-bottom: 2rem;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    background: white;
    border-radius: 14px;
    border: 1px solid rgba(0, 0, 0, 0.04);
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .related-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
    border-color: rgba(20, 184, 166, 0.15);
  }

  .related-cat {
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #14b8a6;
    margin-bottom: 0.5rem;
  }

  .related-title {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 600;
    color: #111827;
    line-height: 1.35;
    margin: 0 0 0.5rem;
  }

  .related-desc {
    font-size: 0.8125rem;
    line-height: 1.6;
    color: #64748b;
    margin: 0 0 auto;
    padding-bottom: 0.75rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .related-link {
    font-size: 0.75rem;
    font-weight: 600;
    color: #94a3b8;
    padding-top: 0.75rem;
    border-top: 1px solid rgba(0, 0, 0, 0.04);
    transition: color 0.2s ease;
  }

  .related-card:hover .related-link {
    color: #14b8a6;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .post-hero {
      padding: 6.5rem 0 3rem;
    }

    .post-title {
      font-size: 2rem;
    }

    .post-desc {
      font-size: 1rem;
    }

    .prose {
      font-size: 1rem;
    }

    .prose :global(h2) {
      font-size: 1.5rem;
    }

    .related-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .post-title {
      font-size: 1.75rem;
    }

    .post-hero-inner,
    .post-body-inner {
      padding: 0 1.25rem;
    }
  }
</style>
