---
interface Props {
  title: string;
  description?: string;
  decorator?: string;
  align?: 'center' | 'left' | 'right';
  className?: string;
  light?: boolean;
}

const { title, description, decorator, align = 'center', className = '', light = false } = Astro.props;
---

<div class={`section-header ${className}`} data-align={align}>
  {decorator && <span class:list={["decorator", { "decorator-light": light }]}>{decorator}</span>}
  <h2 class="section-title">{title}</h2>
  {description && <p class:list={["section-desc", { "desc-light": light }]}>{description}</p>}
</div>

<style>
  .section-header {
    margin-bottom: 3.5rem;
  }

  .section-header[data-align="center"] {
    text-align: center;
  }
  .section-header[data-align="left"] {
    text-align: left;
  }

  .decorator {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #14b8a6;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(20, 184, 166, 0.25);
  }

  .decorator-light {
    color: #0d9488;
    border-bottom-color: rgba(13, 148, 136, 0.2);
  }

  .section-title {
    font-family: var(--font-heading);
    font-size: 2.75rem;
    font-weight: 400;
    line-height: 1.1;
    margin-bottom: 1.25rem;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }

  .section-desc {
    font-size: 1rem;
    color: var(--color-text-secondary);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.7;
    letter-spacing: 0.005em;
  }

  .desc-light {
    color: #64748b;
  }

  .section-header[data-align="left"] .section-desc {
    margin: 0;
  }

  @media (max-width: 768px) {
    .section-header {
      margin-bottom: 2.5rem;
    }

    .section-title {
      font-size: 2.125rem;
    }

    .section-desc {
      font-size: 0.9375rem;
    }
  }

  @media (max-width: 480px) {
    .section-title {
      font-size: 1.75rem;
    }
  }
</style>
