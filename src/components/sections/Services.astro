---
const services = [
  {
    num: "01",
    title: "Cápsula Audiovisual",
    desc: "Preproducción, producción periodística y realización a cargo de un equipo con 20 años de trayectoria.",
    icon: `<polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/>`
  },
  {
    num: "02",
    title: "Cápsula para RRSS",
    desc: "Formato corto enfocado en redes sociales del cliente.",
    icon: `<rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>`
  },
  {
    num: "03",
    title: "Cápsula Vertical",
    desc: "Formato vertical para Reels, TikTok y stories.",
    icon: `<rect x="7" y="2" width="10" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/>`
  },
  {
    num: "04",
    title: "Material Sin Editar",
    desc: "Entrega del material grabado para áreas de marketing y comunicaciones.",
    icon: `<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>`
  },
  {
    num: "05",
    title: "Nota Editorial Web",
    desc: "Redacción editorial con fotos de apoyo y enlace de YouTube para Tour Innovación.",
    icon: `<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>`
  },
  {
    num: "06",
    title: "Exhibición TV Paga",
    desc: "Tandas comerciales en CNN Chile, 13C, T13 en Vivo y Mega 2.",
    icon: `<rect x="2" y="7" width="20" height="15" rx="2" ry="2"/><polyline points="17 2 12 7 7 2"/>`
  },
  {
    num: "07",
    title: "Exhibición Emol TV",
    desc: "Cápsula vertical en Emol TV durante 7 días, máximo 5 minutos.",
    icon: `<circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/>`
  }
];
---

<section id="servicios" class="services">
  <div class="services-inner">
    <!-- Header -->
    <div class="services-header">
      <span class="decorator">Servicios</span>
      <h2 class="services-title">
        Generación de contenido<br/>en diferentes formatos
      </h2>
      <p class="services-desc">
        Contenido audiovisual en distintos formatos en alianza con los medios para llegar a las audiencias actuales.
      </p>
    </div>

    <!-- Grid -->
    <div class="services-grid">
      {services.map((s) => (
        <article class="svc">
          <div class="svc-top">
            <div class="svc-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={s.icon} />
            </div>
            <span class="svc-num">{s.num}</span>
          </div>
          <h3 class="svc-title">{s.title}</h3>
          <p class="svc-desc">{s.desc}</p>
          <div class="svc-line"></div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .services {
    position: relative;
    background: linear-gradient(170deg, #020617 0%, #0c1222 50%, #091118 100%);
    padding: 7rem 0;
    overflow: hidden;
  }

  .services::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(rgba(255,255,255,0.015) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.015) 1px, transparent 1px);
    background-size: 72px 72px;
    pointer-events: none;
  }

  .services-inner {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* ── Header ── */
  .services-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .decorator {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #2dd4bf;
    margin-bottom: 1rem;
  }

  .decorator::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #14b8a6;
  }

  .services-title {
    font-family: var(--font-heading);
    font-size: 2.75rem;
    font-weight: 400;
    line-height: 1.1;
    color: #f1f5f9;
    letter-spacing: -0.01em;
    margin: 0 0 1.25rem 0;
  }

  .services-desc {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: #64748b;
    max-width: 480px;
    margin: 0 auto;
  }

  /* ── Grid ── */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: rgba(255, 255, 255, 0.04);
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  /* ── Card ── */
  .svc {
    padding: 2rem;
    background: rgba(2, 6, 23, 0.8);
    transition: all 0.35s ease;
    position: relative;
  }

  .svc:hover {
    background: rgba(20, 184, 166, 0.06);
  }

  .svc:hover .svc-line {
    width: 100%;
    opacity: 1;
  }

  .svc:hover .svc-icon {
    background: rgba(20, 184, 166, 0.15);
    color: #2dd4bf;
    border-color: rgba(20, 184, 166, 0.3);
  }

  .svc:hover .svc-num {
    color: rgba(20, 184, 166, 0.4);
  }

  /* Top row: icon + number */
  .svc-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;
  }

  .svc-icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.06);
    color: #94a3b8;
    transition: all 0.3s ease;
  }

  .svc-num {
    font-size: 0.75rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.08);
    font-variant-numeric: tabular-nums;
    transition: color 0.3s ease;
  }

  .svc-title {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 600;
    color: #e2e8f0;
    margin: 0 0 0.5rem;
    line-height: 1.3;
  }

  .svc-desc {
    font-size: 0.8125rem;
    line-height: 1.6;
    color: #64748b;
    margin: 0;
  }

  .svc-line {
    position: absolute;
    bottom: 0;
    left: 0;
    height: 2px;
    width: 0;
    background: linear-gradient(90deg, #14b8a6, #2dd4bf);
    opacity: 0;
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* First row: 4 items. Second row: 3 items spanning 4 cols */
  .svc:nth-child(5) { grid-column: 1 / 2; }
  .svc:nth-child(6) { grid-column: 2 / 3; }
  .svc:nth-child(7) { grid-column: 3 / 5; }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .svc:nth-child(5),
    .svc:nth-child(6),
    .svc:nth-child(7) {
      grid-column: auto;
    }

    .services-title {
      font-size: 2.5rem;
    }
  }

  @media (max-width: 768px) {
    .services {
      padding: 5rem 0;
    }

    .services-inner {
      padding: 0 1.25rem;
    }

    .services-title {
      font-size: 2.125rem;
    }

    .services-grid {
      grid-template-columns: 1fr;
      border-radius: 16px;
    }

    .svc {
      padding: 1.5rem;
    }
  }

  @media (max-width: 480px) {
    .services-title {
      font-size: 1.75rem;
    }
  }
</style>
