const graphicServices = [
  {
    num: "01",
    title: "Gráficas de Gran Formato",
    desc: "Llevamos tu marca a lo grande. Soluciones gráficas de alta resolución y durabilidad para exhibiciones, retail, eventos y publicidad exterior. Trabajamos con tela PVC, textil, adhesivos, sintra, FOAM, PAI, madera y más.",
    icon: `<rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>`
  },
  {
    num: "02",
    title: "Impresión Digital y Offset",
    desc: "Papelería corporativa y material publicitario de máxima calidad: tarjetas de presentación, volantes, dípticos, trípticos, carpetas, catálogos y piezas a medida, en bajo volumen o tirajes masivos.",
    icon: `<polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/>`
  },
  {
    num: "03",
    title: "Merchandising Corporativo",
    desc: "Artículos promocionales personalizados, memorables y funcionales alineados con la identidad de tu empresa. Ideales para campañas de fidelización, regalos corporativos y eventos.",
    icon: `<path d="M20 12V22H4V12"/><path d="M22 7H2v5h20V7z"/><path d="M12 22V7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/>`
  },
  {
    num: "04",
    title: "Ficticios y Estructuras a Medida",
    desc: "Si puedes imaginarlo, nosotros podemos construirlo. Elementos 3D y estructuras especiales para activaciones de marca (BTL) y puntos de venta: contenedores intervenidos, ruletas interactivas, stands y exhibidores únicos.",
    icon: `<path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>`
  }
];
---

<section id="servicios" class="services" aria-label="Nuestros servicios: Tour Innovación y Tour Graphic">
  <div class="services-inner">

    <!-- ── TOUR INNOVACIÓN ── -->
    <div class="platform-block">
      <div class="platform-header">
        <span class="platform-badge innovation-badge">Tour Innovación</span>
        <h2 class="services-title">
          Generación de contenido<br/>en diferentes formatos
        </h2>
        <p class="services-desc">
          Tour Innovación es nuestra plataforma estratégica para la creación de contenido en diversos formatos y en alianza con medios para alcanzar a las audiencias actuales.
        </p>
      </div>

      <!-- Video Tour Innovación -->
      <div class="graphic-video-wrapper innovation-video-wrapper">
        <!-- title describe el contenido del video a crawlers y lectores de pantalla -->
        <video
          class="graphic-video"
          id="video-innovacion"
          src="/videos/tour-innovacion.mp4"
          title="Tour Innovación — Contenido audiovisual en alianza con medios de TV paga y Emol TV"
          muted
          loop
          playsinline
          webkit-playsinline
          preload="metadata"
          aria-label="Video demostrativo de Tour Innovación"
        ></video>
        <div class="graphic-video-overlay">
          <span class="graphic-video-label innovation-label">Tour Innovación</span>
        </div>
        <div class="video-controls">
          <button class="video-btn play-btn" data-video="video-innovacion" aria-label="Reproducir/Pausar">
            <svg class="icon-play" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            <svg class="icon-pause" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" style="display:none"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
          </button>
          <button class="video-btn mute-btn" data-video="video-innovacion" aria-label="Silenciar/Activar sonido">
            <svg class="icon-muted" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/></svg>
            <svg class="icon-sound" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"/></svg>
          </button>
        </div>
      </div>

      <div class="services-grid">
        {innovacionServices.map((s) => (
          <article class="svc">
            <div class="svc-top">
              <div class="svc-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={s.icon} />
              </div>
              <span class="svc-num">{s.num}</span>
            </div>
            <h3 class="svc-title">{s.title}</h3>
            <p class="svc-desc">{s.desc}</p>
            <div class="svc-line"></div>
          </article>
        ))}
      </div>
    </div>

    <!-- ── TOUR GRAPHIC ── -->
    <div class="platform-block platform-block-graphic">
      <div class="platform-header">
        <span class="platform-badge graphic-badge">Tour Graphic</span>
        <h2 class="services-title">
          Publicidad digital<br/>en grandes formatos
        </h2>
        <p class="services-desc">
          Desde nuestra plataforma Tour Graphic nos consolidamos como especialistas en publicidad digital de grandes formatos. Nos distinguimos por nuestra rapidez, experiencia, flexibilidad y excelencia en cada ejecución.
        </p>
      </div>

      <!-- Video Tour Graphic -->
      <div class="graphic-video-wrapper">
        <!-- title describe el contenido del video a crawlers y lectores de pantalla -->
        <video
          class="graphic-video"
          id="video-graphic"
          src="/videos/tour-graphic.mp4"
          title="Tour Graphic — Publicidad digital en grandes formatos a nivel nacional"
          muted
          loop
          playsinline
          webkit-playsinline
          preload="metadata"
          aria-label="Video demostrativo de Tour Graphic"
        ></video>
        <div class="graphic-video-overlay">
          <span class="graphic-video-label">Tour Graphic</span>
        </div>
        <div class="video-controls">
          <button class="video-btn play-btn" data-video="video-graphic" aria-label="Reproducir/Pausar">
            <svg class="icon-play" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            <svg class="icon-pause" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" style="display:none"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
          </button>
          <button class="video-btn mute-btn" data-video="video-graphic" aria-label="Silenciar/Activar sonido">
            <svg class="icon-muted" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/></svg>
            <svg class="icon-sound" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"/></svg>
          </button>
        </div>
      </div>

      <div class="services-grid services-grid-graphic">
        {graphicServices.map((s) => (
          <article class="svc svc-graphic">
            <div class="svc-top">
              <div class="svc-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={s.icon} />
              </div>
              <span class="svc-num">{s.num}</span>
            </div>
            <h3 class="svc-title">{s.title}</h3>
            <p class="svc-desc">{s.desc}</p>
            <div class="svc-line svc-line-graphic"></div>
          </article>
        ))}
      </div>
    </div>

  </div>
</section>

<style>
  .services {
    position: relative;
    background: linear-gradient(170deg, #020617 0%, #0c1222 50%, #091118 100%);
    padding: 7rem 0;
    overflow: hidden;
  }

  .services::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(rgba(255,255,255,0.015) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.015) 1px, transparent 1px);
    background-size: 72px 72px;
    pointer-events: none;
  }

  .services-inner {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    flex-direction: column;
    gap: 6rem;
  }

  /* ── Platform Blocks ── */
  .platform-block {}

  .platform-block-graphic {}

  /* ── Platform Header ── */
  .platform-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .platform-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 0.375rem 1rem;
    border-radius: 100px;
    margin-bottom: 1.25rem;
  }

  .innovation-badge {
    color: #2dd4bf;
    background: rgba(20, 184, 166, 0.1);
    border: 1px solid rgba(20, 184, 166, 0.2);
  }

  .innovation-badge::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #14b8a6;
  }

  .graphic-badge {
    color: #a78bfa;
    background: rgba(139, 92, 246, 0.1);
    border: 1px solid rgba(139, 92, 246, 0.2);
  }

  .graphic-badge::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #8b5cf6;
  }

  .services-title {
    font-family: var(--font-heading);
    font-size: 2.75rem;
    font-weight: 400;
    line-height: 1.1;
    color: #f1f5f9;
    letter-spacing: -0.01em;
    margin: 0 0 1.25rem 0;
  }

  .services-desc {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: #64748b;
    max-width: 560px;
    margin: 0 auto;
  }

  /* ── Grid ── */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: rgba(255, 255, 255, 0.04);
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  .services-grid-graphic {
    grid-template-columns: repeat(2, 1fr);
    background: rgba(139, 92, 246, 0.04);
    border-color: rgba(139, 92, 246, 0.08);
  }

  /* ── Card ── */
  .svc {
    padding: 2rem;
    background: rgba(2, 6, 23, 0.8);
    transition: all 0.35s ease;
    position: relative;
  }

  .svc:hover {
    background: rgba(20, 184, 166, 0.06);
  }

  .svc:hover .svc-line {
    width: 100%;
    opacity: 1;
  }

  .svc:hover .svc-icon {
    background: rgba(20, 184, 166, 0.15);
    color: #2dd4bf;
    border-color: rgba(20, 184, 166, 0.3);
  }

  .svc:hover .svc-num {
    color: rgba(20, 184, 166, 0.4);
  }

  /* Tour Graphic card hover */
  .svc-graphic:hover {
    background: rgba(139, 92, 246, 0.06);
  }

  .svc-graphic:hover .svc-icon {
    background: rgba(139, 92, 246, 0.15);
    color: #a78bfa;
    border-color: rgba(139, 92, 246, 0.3);
  }

  .svc-graphic:hover .svc-num {
    color: rgba(139, 92, 246, 0.4);
  }

  /* Top row: icon + number */
  .svc-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;
  }

  .svc-icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.06);
    color: #94a3b8;
    transition: all 0.3s ease;
  }

  .svc-num {
    font-size: 0.75rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.08);
    font-variant-numeric: tabular-nums;
    transition: color 0.3s ease;
  }

  .svc-title {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 600;
    color: #e2e8f0;
    margin: 0 0 0.5rem;
    line-height: 1.3;
  }

  .svc-desc {
    font-size: 0.8125rem;
    line-height: 1.6;
    color: #64748b;
    margin: 0;
  }

  .svc-line {
    position: absolute;
    bottom: 0;
    left: 0;
    height: 2px;
    width: 0;
    background: linear-gradient(90deg, #14b8a6, #2dd4bf);
    opacity: 0;
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .svc-line-graphic {
    background: linear-gradient(90deg, #8b5cf6, #a78bfa);
  }

  /* Tour Innovación: last 3 items layout on second row */
  .services-grid .svc:nth-child(5) { grid-column: 1 / 2; }
  .services-grid .svc:nth-child(6) { grid-column: 2 / 3; }
  .services-grid .svc:nth-child(7) { grid-column: 3 / 5; }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .services-grid .svc:nth-child(5),
    .services-grid .svc:nth-child(6),
    .services-grid .svc:nth-child(7) {
      grid-column: auto;
    }

    .services-grid-graphic {
      grid-template-columns: repeat(2, 1fr);
    }

    .services-title {
      font-size: 2.5rem;
    }
  }

  @media (max-width: 768px) {
    .services {
      padding: 5rem 0;
    }

    .services-inner {
      padding: 0 1.25rem;
      gap: 4rem;
    }

    .services-title {
      font-size: 2.125rem;
    }

    .services-grid,
    .services-grid-graphic {
      grid-template-columns: 1fr;
      border-radius: 16px;
    }

    .svc {
      padding: 1.5rem;
    }

    .platform-header {
      margin-bottom: 2rem;
    }

    .graphic-video-wrapper {
      border-radius: 12px;
      margin-bottom: 1.5rem;
    }
  }

  @media (max-width: 480px) {
    .services-title {
      font-size: 1.75rem;
    }

    .platform-header {
      margin-bottom: 1.5rem;
    }

    .services-title br {
      display: none;
    }
  }

  /* ── Video Tour Graphic ── */
  .graphic-video-wrapper {
    position: relative;
    width: 100%;
    border-radius: 20px;
    overflow: hidden;
    margin-bottom: 1.5rem;
    border: 1px solid rgba(139, 92, 246, 0.15);
    background: #000;
    aspect-ratio: 16 / 9;
  }

  .graphic-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .graphic-video-overlay {
    position: absolute;
    bottom: 1.25rem;
    left: 1.25rem;
    pointer-events: none;
  }

  .graphic-video-label {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.875rem;
    background: rgba(139, 92, 246, 0.85);
    backdrop-filter: blur(8px);
    border-radius: 100px;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: white;
  }

  .graphic-video-label::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #e9d5ff;
  }

  /* Badge teal para Tour Innovación */
  .innovation-label {
    background: rgba(20, 184, 166, 0.85) !important;
  }
  .innovation-label::before {
    background: #a7f3d0 !important;
  }

  /* Botones más grandes en mobile */
  @media (max-width: 768px) {
    .video-btn {
      width: 48px;
      height: 48px;
    }
    .video-controls {
      bottom: 0.875rem;
      right: 0.875rem;
      gap: 0.625rem;
    }
  }

  /* ── Video Controls ── */
  .video-controls {
    position: absolute;
    bottom: 1.25rem;
    right: 1.25rem;
    display: flex;
    gap: 0.5rem;
    z-index: 10;
    pointer-events: auto;
  }

  .video-btn {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: none;
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(8px);
    color: white;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .video-btn:hover {
    background: rgba(0, 0, 0, 0.8);
    transform: scale(1.08);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // ── Play/Pause on viewport visibility ──
    const videos = document.querySelectorAll<HTMLVideoElement>('.graphic-video');

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        const video = entry.target as HTMLVideoElement;
        const playBtn = document.querySelector<HTMLButtonElement>(`.play-btn[data-video="${video.id}"]`);
        if (entry.isIntersecting) {
          video.play().catch(() => {});
          if (playBtn) {
            playBtn.querySelector('.icon-play')!.setAttribute('style', 'display:none');
            playBtn.querySelector('.icon-pause')!.setAttribute('style', '');
          }
        } else {
          video.pause();
          if (playBtn) {
            playBtn.querySelector('.icon-play')!.setAttribute('style', '');
            playBtn.querySelector('.icon-pause')!.setAttribute('style', 'display:none');
          }
        }
      });
    }, { threshold: 0.1 });

    videos.forEach(v => observer.observe(v));

    // ── Play/Pause button ──
    document.querySelectorAll<HTMLButtonElement>('.play-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const video = document.getElementById(btn.dataset.video!) as HTMLVideoElement;
        if (!video) return;
        if (video.paused) {
          video.play();
          btn.querySelector('.icon-play')!.setAttribute('style', 'display:none');
          btn.querySelector('.icon-pause')!.setAttribute('style', '');
        } else {
          video.pause();
          btn.querySelector('.icon-play')!.setAttribute('style', '');
          btn.querySelector('.icon-pause')!.setAttribute('style', 'display:none');
        }
      });
    });

    // ── Mute/Unmute button ──
    document.querySelectorAll<HTMLButtonElement>('.mute-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const video = document.getElementById(btn.dataset.video!) as HTMLVideoElement;
        if (!video) return;
        video.muted = !video.muted;
        if (video.muted) {
          btn.querySelector('.icon-muted')!.setAttribute('style', '');
          btn.querySelector('.icon-sound')!.setAttribute('style', 'display:none');
        } else {
          btn.querySelector('.icon-muted')!.setAttribute('style', 'display:none');
          btn.querySelector('.icon-sound')!.setAttribute('style', '');
        }
      });
    });
  });
</script>
