---
import { teamMembers } from '@/data/team';

const topRow = teamMembers.slice(0, 4);
const bottomRow = teamMembers.slice(4);
---

<section id="equipo" class="team">
  <div class="team-inner">
    <!-- Header -->
    <div class="section-header">
      <span class="decorator">Nuestro Equipo</span>
      <h2 class="section-title">Equipo Profesional</h2>
      <p class="section-desc">
        Profesionales con amplia trayectoria en la industria y los medios, con equipamiento audiovisual de alta calidad.
      </p>
    </div>

    <!-- Row 1: 4 members -->
    <div class="team-row team-row-4">
      {topRow.map((member) => (
        <article class="member">
          <div class="member-photo">
            {member.image ? (
              <img src={member.image} alt={member.name} loading="lazy" />
            ) : (
              <div class="member-placeholder">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                  <circle cx="12" cy="7" r="4"/>
                </svg>
              </div>
            )}
          </div>
          <h3 class="member-name">{member.name}</h3>
          <p class="member-role">{member.role}</p>
          {member.social?.linkedin && (
            <a href={member.social.linkedin} target="_blank" rel="noopener noreferrer" class="member-link" aria-label={`LinkedIn de ${member.name}`}>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
          )}
        </article>
      ))}
    </div>

    <!-- Row 2: 3 members (centered) -->
    <div class="team-row team-row-3">
      {bottomRow.map((member) => (
        <article class="member">
          <div class="member-photo">
            {member.image ? (
              <img src={member.image} alt={member.name} loading="lazy" />
            ) : (
              <div class="member-placeholder">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                  <circle cx="12" cy="7" r="4"/>
                </svg>
              </div>
            )}
          </div>
          <h3 class="member-name">{member.name}</h3>
          <p class="member-role">{member.role}</p>
          {member.social?.linkedin && (
            <a href={member.social.linkedin} target="_blank" rel="noopener noreferrer" class="member-link" aria-label={`LinkedIn de ${member.name}`}>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
          )}
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .team {
    position: relative;
    background: #f8fafc;
    padding: 7rem 0;
  }

  .team-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* ── Header ── */
  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .decorator {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #0d9488;
    margin-bottom: 0.875rem;
  }

  .decorator::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #14b8a6;
  }

  .section-title {
    font-family: var(--font-heading);
    font-size: 2.75rem;
    font-weight: 400;
    line-height: 1.1;
    color: #111827;
    letter-spacing: -0.01em;
    margin: 0 0 1rem 0;
  }

  .section-desc {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: #6b7280;
    max-width: 480px;
    margin: 0 auto;
  }

  /* ── Grid Rows ── */
  .team-row {
    display: grid;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .team-row:last-child {
    margin-bottom: 0;
  }

  .team-row-4 {
    grid-template-columns: repeat(4, 1fr);
  }

  .team-row-3 {
    grid-template-columns: repeat(3, 1fr);
    max-width: 820px;
    margin-left: auto;
    margin-right: auto;
  }

  /* ── Member Card ── */
  .member {
    text-align: center;
    padding: 2rem 1.25rem 1.75rem;
    background: white;
    border-radius: 16px;
    border: 1px solid rgba(0, 0, 0, 0.04);
    transition: all 0.3s ease;
    position: relative;
  }

  .member:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.08);
    border-color: rgba(20, 184, 166, 0.15);
  }

  /* ── Photo ── */
  .member-photo {
    width: 96px;
    height: 96px;
    margin: 0 auto 1.25rem;
    border-radius: 50%;
    overflow: hidden;
    position: relative;
  }

  .member-photo::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 2px solid rgba(20, 184, 166, 0.2);
    pointer-events: none;
  }

  .member:hover .member-photo::after {
    border-color: rgba(20, 184, 166, 0.5);
  }

  .member-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .member:hover .member-photo img {
    transform: scale(1.05);
  }

  .member-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #e2e8f0, #cbd5e1);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #94a3b8;
  }

  /* ── Info ── */
  .member-name {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 600;
    color: #111827;
    margin: 0 0 0.25rem;
    line-height: 1.3;
  }

  .member-role {
    font-size: 0.75rem;
    color: #64748b;
    margin: 0;
    line-height: 1.4;
  }

  .member-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    margin-top: 0.75rem;
    border-radius: 6px;
    color: #94a3b8;
    background: #f1f5f9;
    transition: all 0.2s ease;
  }

  .member-link:hover {
    color: white;
    background: #14b8a6;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .team-row-4 {
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
    }

    .team-row-3 {
      gap: 1rem;
    }

    .section-title {
      font-size: 2.5rem;
    }
  }

  @media (max-width: 768px) {
    .team {
      padding: 5rem 0;
    }

    .team-inner {
      padding: 0 1.25rem;
    }

    .section-title {
      font-size: 2.125rem;
    }

    .team-row-4 {
      grid-template-columns: repeat(2, 1fr);
    }

    .team-row-3 {
      grid-template-columns: repeat(2, 1fr);
      max-width: 100%;
    }

    .member {
      padding: 1.5rem 1rem 1.25rem;
    }

    .member-photo {
      width: 80px;
      height: 80px;
    }
  }

  @media (max-width: 480px) {
    .section-title {
      font-size: 1.75rem;
    }

    .team-row-4,
    .team-row-3 {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.75rem;
    }

    .member {
      padding: 1.25rem 0.75rem 1rem;
    }

    .member-photo {
      width: 72px;
      height: 72px;
      margin-bottom: 1rem;
    }

    .member-name {
      font-size: 0.8125rem;
    }

    .member-role {
      font-size: 0.6875rem;
    }
  }
</style>
