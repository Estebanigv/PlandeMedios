---
/**
 * Contact Section
 * Displays contact form and contact information
 */

import { siteConfig } from '@/data/site';
import { Mail, Phone, Send } from 'lucide-astro';
---

<section id="contacto" class="relative py-32 bg-gradient-to-br from-slate-950 via-slate-900 to-slate-950 overflow-hidden" aria-label="Contacto — Conversemos sobre tu proyecto">
  <!-- Background grid -->
  <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-[size:64px_64px]"></div>

  <!-- Gradient orbs -->
  <div class="absolute top-1/4 right-0 w-96 h-96 bg-gradient-to-br from-teal-500/10 to-emerald-500/10 rounded-full blur-3xl"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-16">
      <span class="inline-flex items-center gap-2 text-xs uppercase font-semibold text-teal-400 mb-4" style="letter-spacing: 0.12em;"><span class="w-1.5 h-1.5 rounded-full bg-teal-400 inline-block"></span>Contacto</span>
      <h2 class="text-white mb-4" style="font-family: var(--font-heading); font-weight: 400; letter-spacing: -0.01em; line-height: 1.1; font-size: clamp(2.125rem, 4vw, 2.75rem);">
        Conversemos sobre tu proyecto
      </h2>
      <p class="text-base text-gray-400 max-w-lg mx-auto" style="line-height: 1.7;">
        Estamos listos para ayudarte a crear contenido que conecte con tu audiencia.
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-12">
      <!-- Contact Form -->
      <div>
        <form
          class="space-y-6"
          id="contactForm"
          action="https://formsubmit.co/joseluis.andraca@plandemedios.cl"
          method="POST"
        >
          <!-- FormSubmit config -->
          <input type="hidden" name="_subject" value="Nuevo contacto desde plandemedios.cl" />
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_template" value="table" />

          <div class="grid sm:grid-cols-2 gap-6">
            <div>
              <label for="name" class="block mb-2 text-gray-300 text-sm">
                Nombre completo *
              </label>
              <input
                id="name"
                name="name"
                type="text"
                required
                placeholder="Tu nombre"
                class="w-full px-4 py-3 bg-white/5 border border-white/10 text-white placeholder:text-gray-500 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500/50 focus:border-teal-500/50 transition-all"
              />
            </div>
            <div>
              <label for="email" class="block mb-2 text-gray-300 text-sm">
                Email *
              </label>
              <input
                id="email"
                name="email"
                type="email"
                required
                placeholder="tu@email.com"
                class="w-full px-4 py-3 bg-white/5 border border-white/10 text-white placeholder:text-gray-500 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500/50 focus:border-teal-500/50 transition-all"
              />
            </div>
          </div>

          <div class="grid sm:grid-cols-2 gap-6">
            <div>
              <label for="company" class="block mb-2 text-gray-300 text-sm">
                Empresa
              </label>
              <input
                id="company"
                name="company"
                type="text"
                placeholder="Nombre de tu empresa"
                class="w-full px-4 py-3 bg-white/5 border border-white/10 text-white placeholder:text-gray-500 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500/50 focus:border-teal-500/50 transition-all"
              />
            </div>
            <div>
              <label for="phone" class="block mb-2 text-gray-300 text-sm">
                Teléfono
              </label>
              <input
                id="phone"
                name="phone"
                type="tel"
                placeholder="+56 9 1234 5678"
                class="w-full px-4 py-3 bg-white/5 border border-white/10 text-white placeholder:text-gray-500 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500/50 focus:border-teal-500/50 transition-all"
              />
            </div>
          </div>

          <div>
            <label for="message" class="block mb-2 text-gray-300 text-sm">
              Mensaje *
            </label>
            <textarea
              id="message"
              name="message"
              required
              placeholder="Cuéntanos sobre tu proyecto..."
              rows="5"
              class="w-full px-4 py-3 bg-white/5 border border-white/10 text-white placeholder:text-gray-500 rounded-lg focus:outline-none focus:ring-2 focus:ring-teal-500/50 focus:border-teal-500/50 transition-all resize-none"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full px-6 py-3 bg-gradient-to-r from-teal-600 to-emerald-700 hover:from-teal-700 hover:to-emerald-800 text-white rounded-lg shadow-lg hover:shadow-xl transition-all flex items-center justify-center gap-2 font-medium"
          >
            Enviar mensaje
            <Send size={18} />
          </button>
        </form>

        <!-- WhatsApp Button -->
        <div class="mt-8">
          <a
            href="https://wa.me/56977771499?text=Hola%2C%20me%20gustaría%20conocer%20más%20sobre%20sus%20servicios"
            target="_blank"
            rel="noopener noreferrer"
            class="block"
          >
            <button
              type="button"
              class="w-full px-6 py-3 border-2 border-green-500/50 bg-white/5 text-green-400 hover:bg-green-500/10 hover:border-green-400 rounded-lg transition-all flex items-center justify-center gap-2 font-medium"
            >
              <Phone size={18} />
              Contactar por WhatsApp
            </button>
          </a>
        </div>
      </div>

      <!-- Contact Info -->
      <div class="space-y-6">
        <div class="border border-white/10 bg-white/5 backdrop-blur-sm shadow-xl rounded-xl p-8">
          <div class="flex items-start gap-4 mb-6">
            <div class="w-12 h-12 bg-gradient-to-br from-teal-600 to-emerald-700 rounded-lg flex items-center justify-center flex-shrink-0 shadow-lg">
              <Mail class="text-white" size={20} />
            </div>
            <div>
              <h4 class="mb-2 text-white font-semibold">Email</h4>
              <a href="mailto:contacto@plandemedios.cl" class="text-gray-400 hover:text-teal-400 transition-colors block">contacto@plandemedios.cl</a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-12 h-12 bg-gradient-to-br from-teal-600 to-emerald-700 rounded-lg flex items-center justify-center flex-shrink-0 shadow-lg">
              <Phone class="text-white" size={20} />
            </div>
            <div>
              <h4 class="mb-2 text-white font-semibold">Teléfono</h4>
              <a href="tel:+56977771499" class="text-gray-400 hover:text-teal-400 transition-colors block">+56 9 7777 1499</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contactForm') as HTMLFormElement | null;
  const btn  = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!btn) return;

    const original = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = 'Enviando…';

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });

      if (res.ok) {
        btn.innerHTML = '✓ Mensaje enviado';
        btn.classList.replace('from-teal-600', 'from-green-600');
        btn.classList.replace('to-emerald-700', 'to-green-700');
        form.reset();
        setTimeout(() => {
          btn.disabled = false;
          btn.innerHTML = original;
          btn.classList.replace('from-green-600', 'from-teal-600');
          btn.classList.replace('to-green-700', 'to-emerald-700');
        }, 4000);
      } else {
        throw new Error('Error al enviar');
      }
    } catch {
      btn.innerHTML = 'Error — intenta de nuevo';
      btn.disabled = false;
      setTimeout(() => { btn.innerHTML = original; }, 3000);
    }
  });
</script>
