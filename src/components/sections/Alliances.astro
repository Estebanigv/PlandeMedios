---
/**
 * Alliances Section — Medios aliados de Plan de Medios
 * CNN Chile, T13 en Vivo, Canal 13C, Emol TV
 */

const alliances = [
  { name: "CNN Chile",      logo: "/images/alianzas/cnn-chile.png"    },
  { name: "T13 en Vivo",    logo: "/images/alianzas/t13.png"          },
  { name: "Canal 13C",      logo: "/images/alianzas/canal-13c.png"    },
  { name: "Emol TV",        logo: "/images/alianzas/emol-tv.png"      },
  { name: "Mega 2",         logo: "/images/alianzas/mega-2.png"       },
  { name: "Mega Ficción",   logo: "/images/alianzas/mega-ficcion.png" },
];
---

<section id="alianzas" class="alliances" aria-label="Medios aliados de Plan de Medios">
  <div class="alliances-inner">
    <p class="alliances-label">Medios donde transmitimos</p>
    <div class="alliances-grid">
      {alliances.map((a) => (
        <div class="alliance-item">
          <img
            src={a.logo}
            alt={`Logo ${a.name}`}
            loading="lazy"
            decoding="async"
          />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .alliances {
    background: #f8fafc;
    border-top: 1px solid rgba(0, 0, 0, 0.05);
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
    padding: 2.5rem 0;
  }

  .alliances-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    align-items: center;
    gap: 3rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .alliances-label {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #94a3b8;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .alliances-grid {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .alliance-item {
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.65;
    transition: opacity 0.2s ease;
    filter: grayscale(0.3);
  }

  .alliance-item:hover {
    opacity: 1;
    filter: grayscale(0);
  }

  .alliance-item img {
    height: 36px;
    width: auto;
    max-width: 120px;
    object-fit: contain;
  }

  @media (max-width: 768px) {
    .alliances-inner {
      gap: 1.5rem;
      padding: 0 1.25rem;
      flex-direction: column;
    }

    .alliances-grid {
      gap: 1.75rem;
    }

    .alliance-item img {
      height: 28px;
    }
  }
</style>
