---
import PlatformCardWithImage from '@/components/features/PlatformCardWithImage.astro';
---

<!-- h1 único de la página: "Conectamos marcas con audiencias reales" -->
<section id="inicio" class="hero" aria-label="Inicio — Plan de Medios, agencia de contenidos">
  <!-- Background -->
  <div class="hero-bg">
    <div class="glow glow-1"></div>
    <div class="glow glow-2"></div>
  </div>

  <div class="hero-inner">
    <div class="hero-grid">
      <!-- Left: Content -->
      <div class="hero-content">
        <div class="hero-badge">
          <span class="badge-pulse"></span>
          <span class="badge-label">Plan de Medios</span>
          <span class="badge-sep"></span>
          <span class="badge-value">Contenidos & Planificación</span>
        </div>

        <h1 class="hero-title">
          Conectamos marcas con
          <em class="highlight">audiencias reales</em>
        </h1>

        <p class="hero-desc">
          Creamos contenido audiovisual y editorial en alianza con medios de comunicación. Estrategia, producción y distribución en un solo equipo.
        </p>

        <ul class="hero-bullets">
          <li>Generamos contenidos en colaboración con los medios.</li>
          <li>Desarrollamos formatos creativos: audiovisuales, editoriales y publicitarios.</li>
          <li>Integramos estrategia, producción y distribución.</li>
        </ul>

        <div class="hero-ctas">
          <a href="#contacto" class="cta-primary">
            Agendar reunión
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="#servicios" class="cta-secondary">
            Ver servicios
          </a>
        </div>

        <div class="trust-bar">
          <div class="trust-item">
            <div class="trust-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div class="trust-text">
              <span class="trust-number">+20 años</span>
              <span class="trust-label">en medios</span>
            </div>
          </div>
          <div class="trust-item">
            <div class="trust-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <div class="trust-text">
              <span class="trust-number">250+ empresas</span>
              <span class="trust-label">confían en nosotros</span>
            </div>
          </div>
          <div class="trust-item">
            <div class="trust-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            </div>
            <div class="trust-text">
              <span class="trust-number">2 plataformas</span>
              <span class="trust-label">especializadas</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Visual -->
      <div class="hero-visual">
        <!--
          priority=true en la primera tarjeta: es LCP candidate (above-the-fold).
          La segunda recibe lazy loading al estar parcialmente fuera de vista inicial.
        -->
        <PlatformCardWithImage
          size="large"
          platform="innovation"
          badge="TOUR INNOVACIÓN"
          title="Tour Innovación"
          subtitle="Creamos contenidos audiovisuales y editoriales en alianza con los medios y plataformas digitales."
          imageSrc="https://images.unsplash.com/photo-1518770660439-4636190af475?w=800&h=600&fit=crop&q=80"
          imageAlt="Estudio de producción audiovisual — Tour Innovación de Plan de Medios"
          priority={true}
        />
        <PlatformCardWithImage
          size="large"
          platform="graphic"
          badge="TOUR GRAPHIC"
          title="Tour Graphic"
          subtitle="Realizamos publicidad digital en grandes formatos. Diseño, distribución e instalación a nivel nacional."
          imageSrc="https://images.unsplash.com/photo-1551818255-e6e10975bc17?w=800&h=600&fit=crop&q=80"
          imageAlt="Publicidad digital en grandes formatos — Tour Graphic de Plan de Medios"
        />
      </div>
    </div>
  </div>
</section>

<style>
  /* ── Section ── */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 8rem 0 5rem;
    overflow: hidden;
  }

  /* ── Background ── */
  .hero-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(170deg, #020617 0%, #0c1222 50%, #091118 100%);
    z-index: -1;
  }

  .hero-bg::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(rgba(255,255,255,0.015) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.015) 1px, transparent 1px);
    background-size: 72px 72px;
  }

  .glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(120px);
    pointer-events: none;
  }

  .glow-1 {
    width: 480px;
    height: 480px;
    background: rgba(20, 184, 166, 0.08);
    top: -5%;
    left: -5%;
  }

  .glow-2 {
    width: 400px;
    height: 400px;
    background: rgba(16, 185, 129, 0.06);
    bottom: 10%;
    right: 5%;
  }

  /* ── Layout ── */
  .hero-inner {
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  /* ── Content ── */
  .hero-content {
    animation: fadeUp 0.7s ease-out;
    padding-top: 2rem;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.4375rem 0.875rem;
    background: rgba(20, 184, 166, 0.08);
    border: 1px solid rgba(20, 184, 166, 0.15);
    border-radius: 100px;
    margin-bottom: 2rem;
    backdrop-filter: blur(8px);
  }

  .badge-pulse {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #2dd4bf;
    box-shadow: 0 0 6px rgba(45, 212, 191, 0.6);
    animation: pulse-glow 2.5s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes pulse-glow {
    0%, 100% { opacity: 1; box-shadow: 0 0 6px rgba(45, 212, 191, 0.6); }
    50% { opacity: 0.5; box-shadow: 0 0 2px rgba(45, 212, 191, 0.3); }
  }

  .badge-label {
    font-size: 0.6875rem;
    font-weight: 600;
    color: #e2e8f0;
    letter-spacing: 0.02em;
  }

  .badge-sep {
    width: 1px;
    height: 12px;
    background: rgba(255, 255, 255, 0.12);
  }

  .badge-value {
    font-size: 0.6875rem;
    font-weight: 500;
    color: #2dd4bf;
    letter-spacing: 0.01em;
  }

  .hero-title {
    font-family: var(--font-heading);
    font-size: 3.5rem;
    font-weight: 400;
    line-height: 1.08;
    color: #f1f5f9;
    letter-spacing: -0.01em;
    margin-bottom: 1.75rem;
  }

  .highlight {
    font-style: italic;
    background: linear-gradient(135deg, #2dd4bf, #14b8a6);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-desc {
    font-size: 1rem;
    line-height: 1.75;
    color: #94a3b8;
    margin-bottom: 1.25rem;
    max-width: 460px;
    letter-spacing: 0.005em;
  }

  /* ── Bullet List ── */
  .hero-bullets {
    list-style: none;
    padding: 0;
    margin: 0 0 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .hero-bullets li {
    font-size: 0.875rem;
    line-height: 1.6;
    color: #94a3b8;
    padding-left: 1.25rem;
    position: relative;
  }

  .hero-bullets li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #2dd4bf;
  }

  /* ── CTAs ── */
  .hero-ctas {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 3.5rem;
  }

  .cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.8125rem 1.75rem;
    background: linear-gradient(135deg, #14b8a6, #0d9488);
    color: white;
    font-weight: 600;
    font-size: 0.875rem;
    border-radius: 10px;
    text-decoration: none;
    transition: all 0.25s ease;
    box-shadow: 0 2px 12px rgba(20, 184, 166, 0.25);
  }

  .cta-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(20, 184, 166, 0.35);
    filter: brightness(1.05);
  }

  .cta-primary svg {
    transition: transform 0.25s ease;
  }

  .cta-primary:hover svg {
    transform: translateX(3px);
  }

  .cta-secondary {
    display: inline-flex;
    align-items: center;
    padding: 0.8125rem 1.75rem;
    color: #cbd5e1;
    font-weight: 500;
    font-size: 0.875rem;
    border-radius: 10px;
    text-decoration: none;
    transition: all 0.25s ease;
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .cta-secondary:hover {
    color: white;
    background: rgba(255, 255, 255, 0.04);
    border-color: rgba(255, 255, 255, 0.15);
  }

  /* ── Trust Bar ── */
  .trust-bar {
    display: flex;
    gap: 1rem;
    padding-top: 2.5rem;
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 12px;
    flex: 1;
  }

  .trust-icon {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(20, 184, 166, 0.1);
    border-radius: 8px;
    color: #2dd4bf;
    flex-shrink: 0;
  }

  .trust-text {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .trust-number {
    font-size: 0.8125rem;
    font-weight: 600;
    color: #f1f5f9;
    line-height: 1.3;
  }

  .trust-label {
    font-size: 0.6875rem;
    color: #64748b;
    line-height: 1.3;
  }

  /* ── Visual ── */
  .hero-visual {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    animation: fadeUp 0.7s ease-out 0.15s both;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ── Responsive ── */
  @media (max-width: 1280px) {
    .hero-title {
      font-size: 3rem;
    }

    .hero-grid {
      gap: 3rem;
    }
  }

  @media (max-width: 1024px) {
    .hero {
      padding: 7rem 0 4rem;
      min-height: auto;
    }

    .hero-grid {
      grid-template-columns: 1fr;
      gap: 3.5rem;
    }

    .hero-title {
      font-size: 3rem;
    }

    .hero-desc {
      max-width: 560px;
    }

    .hero-visual {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      max-width: 100%;
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding: 6.5rem 0 3rem;
    }

    .hero-inner {
      padding: 0 1.25rem;
    }

    .hero-title {
      font-size: 2.5rem;
    }

    .hero-desc {
      font-size: 1rem;
    }

    .hero-ctas {
      flex-direction: column;
      align-items: stretch;
      margin-bottom: 2.5rem;
    }

    .cta-primary,
    .cta-secondary {
      justify-content: center;
    }

    .hero-visual {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      max-height: 500px;
    }

    .trust-bar {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    .trust-item {
      flex: 1;
      min-width: 140px;
    }
  }

  @media (max-width: 480px) {
    .hero-title {
      font-size: 1.875rem;
    }

    .hero-badge {
      flex-wrap: wrap;
    }

    .trust-bar {
      flex-direction: column;
    }
  }
</style>
