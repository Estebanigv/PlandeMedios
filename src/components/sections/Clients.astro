---
/**
 * Cifras Section
 * Key metrics with animated counters
 */

const stats = [
  { value: 250, suffix: "+", label: "Empresas", desc: "han confiado en nosotros" },
  { value: 98, suffix: "%", label: "Retención", desc: "clientes vuelven a elegirnos" },
  { value: 200, suffix: "+", label: "Especiales", desc: "desarrollados con éxito" },
  { value: 15, suffix: "+", label: "Industrias", desc: "de diversos sectores" }
];
---

<section id="cifras" class="cifras">
  <div class="cifras-inner">
    <!-- Header -->
    <div class="cifras-header">
      <span class="decorator">Cifras</span>
      <h2 class="cifras-title">Números que respaldan<br/>nuestra trayectoria</h2>
      <p class="cifras-desc">Desde el 2020 transformando la comunicación de marca en Chile.</p>
    </div>

    <!-- Stats Grid -->
    <div class="stats-grid">
      {stats.map((stat) => (
        <div class="stat-card" data-target={stat.value} data-suffix={stat.suffix}>
          <div class="stat-number-wrap">
            <span class="stat-number" data-value={stat.value}>0</span>
            <span class="stat-suffix">{stat.suffix}</span>
          </div>
          <div class="stat-label">{stat.label}</div>
          <div class="stat-desc">{stat.desc}</div>
          <div class="stat-bar">
            <div class="stat-bar-fill"></div>
          </div>
        </div>
      ))}
    </div>

    <!-- Trust logos text -->
    <div class="trust-footer">
      <p class="trust-text">Alianzas con medios líderes</p>
      <div class="trust-logos">
        <span class="trust-logo">CNN Chile</span>
        <span class="trust-dot"></span>
        <span class="trust-logo">T13 en Vivo</span>
        <span class="trust-dot"></span>
        <span class="trust-logo">Canal 13C</span>
        <span class="trust-dot"></span>
        <span class="trust-logo">Mega 2</span>
        <span class="trust-dot"></span>
        <span class="trust-logo">Emol TV</span>
      </div>
    </div>
  </div>
</section>

<style>
  .cifras {
    position: relative;
    background: linear-gradient(170deg, #020617 0%, #0a1628 50%, #020617 100%);
    padding: 7rem 0;
    overflow: hidden;
  }

  .cifras::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 800px 600px at 30% 20%, rgba(20, 184, 166, 0.06), transparent),
      radial-gradient(ellipse 600px 400px at 70% 80%, rgba(16, 185, 129, 0.04), transparent);
    pointer-events: none;
  }

  .cifras-inner {
    position: relative;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* ── Header ── */
  .cifras-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .decorator {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #2dd4bf;
    margin-bottom: 1rem;
  }

  .decorator::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #14b8a6;
  }

  .cifras-title {
    font-family: var(--font-heading);
    font-size: 2.75rem;
    font-weight: 400;
    line-height: 1.1;
    color: #f1f5f9;
    letter-spacing: -0.01em;
    margin: 0 0 1rem;
  }

  .cifras-desc {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: #64748b;
    max-width: 420px;
    margin: 0 auto;
  }

  /* ── Stats Grid ── */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    margin-bottom: 4rem;
  }

  .stat-card {
    text-align: center;
    padding: 2.5rem 1.5rem 2rem;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 20px;
    transition: all 0.4s ease;
    position: relative;
    overflow: hidden;
  }

  .stat-card:hover {
    background: rgba(20, 184, 166, 0.05);
    border-color: rgba(20, 184, 166, 0.2);
    transform: translateY(-4px);
  }

  .stat-card:hover .stat-bar-fill {
    width: 100%;
  }

  .stat-number-wrap {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 0.125rem;
    margin-bottom: 0.5rem;
  }

  .stat-number {
    font-size: 3.5rem;
    font-weight: 800;
    line-height: 1;
    background: linear-gradient(135deg, #2dd4bf, #14b8a6, #10b981);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.03em;
  }

  .stat-suffix {
    font-size: 2rem;
    font-weight: 700;
    background: linear-gradient(135deg, #2dd4bf, #14b8a6);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .stat-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: #e2e8f0;
    margin-bottom: 0.25rem;
    letter-spacing: 0.01em;
  }

  .stat-desc {
    font-size: 0.75rem;
    color: #64748b;
    line-height: 1.4;
  }

  .stat-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: rgba(255, 255, 255, 0.03);
  }

  .stat-bar-fill {
    height: 100%;
    width: 0;
    background: linear-gradient(90deg, #14b8a6, #2dd4bf);
    border-radius: 0 3px 3px 0;
    transition: width 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* ── Trust Footer ── */
  .trust-footer {
    text-align: center;
    padding-top: 2.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.04);
  }

  .trust-text {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #475569;
    margin-bottom: 1.25rem;
  }

  .trust-logos {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .trust-logo {
    font-size: 0.9375rem;
    font-weight: 600;
    color: #64748b;
    letter-spacing: -0.01em;
    transition: color 0.3s ease;
  }

  .trust-logo:hover {
    color: #2dd4bf;
  }

  .trust-dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: #334155;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .cifras-title {
      font-size: 2.5rem;
    }

    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .cifras {
      padding: 5rem 0;
    }

    .cifras-inner {
      padding: 0 1.25rem;
    }

    .cifras-title {
      font-size: 2.125rem;
    }

    .stat-card {
      padding: 2rem 1.25rem 1.5rem;
    }

    .stat-number {
      font-size: 2.75rem;
    }

    .stat-suffix {
      font-size: 1.5rem;
    }

    .trust-logos {
      gap: 0.75rem;
    }

    .trust-logo {
      font-size: 0.8125rem;
    }
  }

  @media (max-width: 480px) {
    .cifras-title {
      font-size: 1.75rem;
    }

    .stats-grid {
      gap: 0.75rem;
    }

    .stat-number {
      font-size: 2.25rem;
    }
  }
</style>

<script>
  // Animated counter on scroll
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;

      const cards = entry.target.querySelectorAll('.stat-card');
      cards.forEach((card, i) => {
        const numEl = card.querySelector('.stat-number') as HTMLElement;
        const target = parseInt(numEl?.dataset.value || '0');
        if (!numEl || numEl.dataset.animated === 'true') return;
        numEl.dataset.animated = 'true';

        // Stagger animation
        setTimeout(() => {
          const duration = 2000;
          const start = performance.now();

          const animate = (now: number) => {
            const elapsed = now - start;
            const progress = Math.min(elapsed / duration, 1);
            // Ease out cubic
            const eased = 1 - Math.pow(1 - progress, 3);
            numEl.textContent = Math.floor(eased * target).toString();

            if (progress < 1) {
              requestAnimationFrame(animate);
            } else {
              numEl.textContent = target.toString();
            }
          };

          requestAnimationFrame(animate);

          // Animate bar fill
          const bar = card.querySelector('.stat-bar-fill') as HTMLElement;
          if (bar) bar.style.width = '100%';
        }, i * 200);
      });

      observer.unobserve(entry.target);
    });
  }, { threshold: 0.3 });

  const grid = document.querySelector('.stats-grid');
  if (grid) observer.observe(grid);
</script>
