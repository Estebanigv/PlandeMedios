---
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const posts = allPosts
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 5);

const featured = posts[0];
const grid = posts.slice(1, 5);

const formatDate = (date: Date) =>
  date.toLocaleDateString('es-CL', { day: 'numeric', month: 'short' });

const fallbackImg = 'https://images.unsplash.com/photo-1504711434969-e33886168d8c?w=600&h=400&fit=crop&q=80';

const catColors: Record<string, string> = {
  'video': '#f43f5e',
  'audio': '#8b5cf6',
  'contenido': '#f59e0b',
  'marketing digital': '#14b8a6',
  'e-commerce': '#3b82f6',
  'innovación': '#10b981',
  'roi': '#f97316',
  'branding': '#ec4899',
  'estrategia': '#6366f1',
};

const getCatColor = (cat: string) => catColors[cat.toLowerCase()] || '#14b8a6';
---

<section id="noticias" class="noticias">
  <div class="noticias-inner">
    <!-- Header -->
    <div class="noticias-header">
      <div>
        <span class="decorator">Noticias</span>
        <h2 class="noticias-title">Últimas publicaciones</h2>
      </div>
      <a href="/blog" class="view-all">
        Ver todas
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>

    {posts.length > 0 && (
      <div class="news-grid">
        <!-- Featured -->
        <a href={`/blog/${featured.slug}`} class="featured">
          <div class="featured-img">
            <img src={featured.data.image || fallbackImg} alt={featured.data.title} loading="lazy" />
            <div class="img-overlay"></div>
            <span class="cat-badge" style={`background: ${getCatColor(featured.data.category)};`}>{featured.data.category}</span>
          </div>
          <div class="featured-body">
            <h3 class="featured-title">{featured.data.title}</h3>
            <p class="featured-excerpt">{featured.data.description}</p>
            <div class="card-footer">
              <div class="meta">
                <time>{formatDate(featured.data.publishDate)}</time>
                {featured.data.readTime && <span class="dot"></span>}
                {featured.data.readTime && <span>{featured.data.readTime}</span>}
              </div>
              <span class="read-link">Leer artículo →</span>
            </div>
          </div>
        </a>

        <!-- Grid cards -->
        {grid.map((post) => (
          <a href={`/blog/${post.slug}`} class="post-card">
            <div class="post-img">
              <img src={post.data.image || fallbackImg} alt={post.data.title} loading="lazy" />
              <div class="img-overlay"></div>
              <span class="cat-badge cat-badge-sm" style={`background: ${getCatColor(post.data.category)};`}>{post.data.category}</span>
            </div>
            <div class="post-body">
              <h4 class="post-title">{post.data.title}</h4>
              <div class="card-footer">
                <time>{formatDate(post.data.publishDate)}</time>
                <span class="read-link">→</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .noticias {
    position: relative;
    background: #f8fafc;
    padding: 7rem 0;
  }

  .noticias-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* ── Header ── */
  .noticias-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 3rem;
    gap: 2rem;
  }

  .decorator {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #0d9488;
    margin-bottom: 0.75rem;
  }

  .decorator::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #14b8a6;
  }

  .noticias-title {
    font-family: var(--font-heading);
    font-size: 2.75rem;
    font-weight: 400;
    line-height: 1.1;
    color: #111827;
    letter-spacing: -0.01em;
    margin: 0;
  }

  .view-all {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #14b8a6;
    text-decoration: none;
    padding: 0.5rem 1rem;
    border: 1px solid rgba(20, 184, 166, 0.2);
    border-radius: 8px;
    transition: all 0.25s ease;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .view-all:hover {
    background: rgba(20, 184, 166, 0.06);
    border-color: rgba(20, 184, 166, 0.4);
  }

  .view-all svg {
    transition: transform 0.25s ease;
  }

  .view-all:hover svg {
    transform: translateX(3px);
  }

  /* ── Grid ── */
  .news-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: auto auto;
    gap: 1.25rem;
  }

  /* ── Shared ── */
  .img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.2), transparent 60%);
    pointer-events: none;
  }

  .cat-badge {
    position: absolute;
    top: 0.875rem;
    left: 0.875rem;
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: white;
    padding: 0.25rem 0.625rem;
    border-radius: 6px;
    z-index: 1;
  }

  .cat-badge-sm {
    top: 0.625rem;
    left: 0.625rem;
    font-size: 0.5625rem;
    padding: 0.1875rem 0.5rem;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 0.75rem;
    border-top: 1px solid rgba(0, 0, 0, 0.04);
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.6875rem;
    color: #94a3b8;
  }

  .dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: #cbd5e1;
  }

  time {
    font-size: 0.6875rem;
    color: #94a3b8;
  }

  .read-link {
    font-size: 0.75rem;
    font-weight: 600;
    color: #94a3b8;
    transition: color 0.25s ease;
  }

  /* ── Featured ── */
  .featured {
    grid-row: 1 / 3;
    grid-column: 1 / 2;
    display: flex;
    flex-direction: column;
    background: white;
    border-radius: 16px;
    overflow: hidden;
    text-decoration: none;
    border: 1px solid rgba(0, 0, 0, 0.04);
    transition: all 0.3s ease;
  }

  .featured:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.08);
    border-color: rgba(20, 184, 166, 0.15);
  }

  .featured:hover .featured-img img {
    transform: scale(1.04);
  }

  .featured:hover .read-link {
    color: #14b8a6;
  }

  .featured-img {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4 / 3;
  }

  .featured-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .featured-body {
    padding: 1.5rem 1.75rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .featured-title {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 400;
    color: #111827;
    line-height: 1.2;
    margin: 0 0 0.75rem;
  }

  .featured-excerpt {
    font-size: 0.8125rem;
    line-height: 1.7;
    color: #64748b;
    margin: 0 0 auto;
    padding-bottom: 1rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Post Card ── */
  .post-card {
    display: flex;
    flex-direction: column;
    background: white;
    border-radius: 14px;
    overflow: hidden;
    text-decoration: none;
    border: 1px solid rgba(0, 0, 0, 0.04);
    transition: all 0.3s ease;
  }

  .post-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
    border-color: rgba(20, 184, 166, 0.12);
  }

  .post-card:hover .post-img img {
    transform: scale(1.04);
  }

  .post-card:hover .read-link {
    color: #14b8a6;
  }

  .post-img {
    position: relative;
    overflow: hidden;
    aspect-ratio: 16 / 9;
  }

  .post-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .post-body {
    padding: 1rem 1.25rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .post-title {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 600;
    color: #111827;
    line-height: 1.35;
    margin: 0 0 auto;
    padding-bottom: 0.75rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .news-grid {
      grid-template-columns: 1fr 1fr;
    }

    .featured {
      grid-column: 1 / 3;
      grid-row: auto;
    }

    .featured-img {
      aspect-ratio: 21 / 9;
    }

    .noticias-title {
      font-size: 2.5rem;
    }
  }

  @media (max-width: 768px) {
    .noticias {
      padding: 5rem 0;
    }

    .noticias-inner {
      padding: 0 1.25rem;
    }

    .noticias-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .noticias-title {
      font-size: 2.125rem;
    }

    .news-grid {
      grid-template-columns: 1fr;
    }

    .featured {
      grid-column: 1;
    }

    .featured-title {
      font-size: 1.375rem;
    }
  }

  @media (max-width: 480px) {
    .noticias-title {
      font-size: 1.75rem;
    }
  }
</style>
